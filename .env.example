MAX_BOT_TOKEN=replace_with_max_bot_token
MISTRAL_API_KEY=replace_with_mistral_api_key
OWNER_MAX_USER_ID=replace_with_your_max_user_id

# polling for local development, webhook for production
BOT_MODE=polling

# owner keeps the bot private; all lets any MAX user connect their own accounts
ACCESS_MODE=owner

MAX_API_BASE_URL=https://platform-api2.max.ru
MAX_CA_CERT_PATH=russiantrustedca/russiantrustedca2024.pem
MISTRAL_API_BASE_URL=https://api.mistral.ai
MISTRAL_MODEL=mistral-small-latest
SEARCH_API_BASE_URL=http://127.0.0.1:8888
STORE_PATH=data/agent.db

# Required only with BOT_MODE=webhook
WEBHOOK_ADDR=:8080
WEBHOOK_SECRET=replace_with_random_secret

# Required for Gmail / Google Calendar OAuth integration
PUBLIC_BASE_URL=https://your-domain.example
TOKEN_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
